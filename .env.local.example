# Copia questo file in `.env.local` e inserisci i tuoi valori, poi riavvia.

# ── Cervello (obbligatorio) ─────────────────────────────────────────────────
# ORION usa l'API di Claude (modello claude-opus-4-8). Senza chiave l'interfaccia
# parte, ma ORION non può rispondere.
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp reale (opzionale) ──────────────────────────────────────────────
# Se queste 3 variabili sono presenti, ORION invia/riceve davvero via
# WhatsApp Business Cloud API (Meta). Se mancano, WhatsApp resta SIMULATO.
# Guida passo-passo: vedi WHATSAPP.md
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# ── Notifiche push (promemoria automatici) ──────────────────────────────────
# La chiave PUBBLICA è già nel codice. Qui serve solo la PRIVATA (segreta).
# In produzione su Railway aggiungi questa variabile con lo stesso valore.
VAPID_PRIVATE_KEY=

# ── Modelli e costi (opzionale) ─────────────────────────────────────────────
# Routing automatico: richieste operative brevi → modello rapido; il resto →
# modello pieno. ORION_ROUTING=off per usare sempre il modello pieno.
# ORION_MODEL=claude-opus-4-8
# ORION_MODEL_RAPIDO=claude-haiku-4-5-20251001
# ORION_MODEL_TELEFONO=claude-haiku-4-5-20251001
# ORION_ROUTING=on

# ── Cifratura a riposo dei segreti in DB (consigliata) ──────────────────────
# Senza, si usa VAPID_PRIVATE_KEY come chiave. Stringa lunga e casuale.
# ORION_ENC_KEY=

# ── Fatturazione elettronica SDI (opzionale) ────────────────────────────────
# Provider API che firma e inoltra l'XML FatturaPA allo SDI (A-Cube, Openapi…).
# Senza: l'XML viene comunque generato e conservato, pronto da trasmettere.
# Guida: FATTURE.md
# SDI_PROVIDER=acube
# SDI_API_URL=
# SDI_API_KEY=

# ── Centralino telefonico AI (opzionale) ────────────────────────────────────
# Numero Twilio che punta a /api/telefono/webhook. Guida: TELEFONO.md
# TWILIO_VOICE=Polly.Bianca
# ORION_TELEFONO_TENANT=            # id tenant per il numero condiviso (sviluppo)

# ── Google Calendar (opzionale) ─────────────────────────────────────────────
# OAuth "Web application" su console.cloud.google.com; redirect URI:
# https://<dominio>/api/calendario/callback  (guida: CALENDARIO.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Anti no-show (opzionale) ────────────────────────────────────────────────
# Quante ore prima dell'appuntamento parte il promemoria WhatsApp (default 24).
# ORION_REMINDER_ORE=24
