# Copia questo file in `.env.local` e inserisci i tuoi valori, poi riavvia.

# ── Cervello (obbligatorio) ─────────────────────────────────────────────────
# ORION usa l'API di Claude (modello claude-opus-4-8). Senza chiave l'interfaccia
# parte, ma ORION non può rispondere.
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp reale (opzionale) ──────────────────────────────────────────────
# Se queste 3 variabili sono presenti, ORION invia/riceve davvero via
# WhatsApp Business Cloud API (Meta). Se mancano, WhatsApp resta SIMULATO.
# Guida passo-passo: vedi WHATSAPP.md
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
