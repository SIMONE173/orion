{
  "name": "orion-desktop",
  "version": "1.0.0",
  "description": "ORION Desktop — il tuo assistente, con le mani sul computer",
  "main": "main.js",
  "author": "ORION",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.3.3"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "app.orion.desktop",
    "productName": "ORION",
    "files": ["main.js", "preload.js", "whisper.js"],
    "mac": { "category": "public.app-category.productivity", "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
